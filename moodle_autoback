}


parse_bash_scalar_literal () {
    local rest="$1"
    local value
    local numeric_re='^([0-9]+)[[:space:]]*[,;]?[[:space:]]*$'

    rest="${rest#"${rest%%[![:space:]]*}"}"

    case "${rest}" in
        \'*)
            value="${rest#\'}"
            value="${value%%\'*}"
            printf '%s\n' "${value}"
            return 0
            ;;
        \"*)
            value="${rest#\"}"
            value="${value%%\"*}"
            printf '%s\n' "${value}"
            return 0
            ;;
        *)
            if [[ "${rest}" =~ ${numeric_re} ]]; then
                printf '%s\n' "${BASH_REMATCH[1]}"
                return 0
            fi

            return 1
            ;;
    esac
}


parse_moodle_config_with_bash () {
    local line
    local key
    local rest
    local value
    local in_dboptions="false"
    # shellcheck disable=SC2016
    local assignment_re='^[[:space:]]*\$CFG->([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=[[:space:]]*(.*)$'
    # shellcheck disable=SC2016
    local dboptions_start_re='^[[:space:]]*\$CFG->dboptions[[:space:]]*=[[:space:]]*array[[:space:]]*\('
    local dboptions_end_re='^[[:space:]]*\)[[:space:]]*;'
    # shellcheck disable=SC2016
    local dboptions_port_assignment_re="^[[:space:]]*\\\$CFG->dboptions\\[['\\\"]dbport['\\\"]\\][[:space:]]*=[[:space:]]*(.*)$"
    local dboptions_port_entry_re="^[[:space:]]*['\\\"]dbport['\\\"][[:space:]]*=>[[:space:]]*(.*)$"

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ${dboptions_port_assignment_re} ]]; then
            rest="${BASH_REMATCH[1]}"

            if value="$(parse_bash_scalar_literal "${rest}")"; then
                assign_config_value "dbport" "${value}"
            fi

            continue
        fi

        if [[ "${line}" =~ ${dboptions_start_re} ]]; then
            in_dboptions="true"
        fi

        if [[ "${in_dboptions}" == "true" && "${line}" =~ ${dboptions_port_entry_re} ]]; then
            rest="${BASH_REMATCH[1]}"

            if value="$(parse_bash_scalar_literal "${rest}")"; then
                assign_config_value "dbport" "${value}"
            fi
        fi

        if [[ "${in_dboptions}" == "true" && "${line}" =~ ${dboptions_end_re} ]]; then
            in_dboptions="false"
        fi

        if [[ ! "${line}" =~ ${assignment_re} ]]; then
            continue
        fi

        key="${BASH_REMATCH[1]}"
        rest="${BASH_REMATCH[2]}"

        if value="$(parse_bash_scalar_literal "${rest}")"; then
            assign_config_value "${key}" "${value}"
        fi
    done < "${CONFIG_FILE}"

    if [[ "${CFG_HAVE_PREFIX}" != "true" ]]; then
        CFG_PREFIX=""
    fi

    CONFIG_PARSER="bash"
}


parse_moodle_config () {
    if parse_moodle_config_with_php; then
        return
    fi

    parse_moodle_config_with_bash
}


require_config_key () {
    local key="$1"
    local present="$2"

    if [[ "${present}" != "true" ]]; then
        die "required Moodle config value not found: \$CFG->${key}"
    fi
}


validate_config () {
    local dataroot
    local resolved

    require_config_key "dbtype" "${CFG_HAVE_DBTYPE}"
    require_config_key "dbhost" "${CFG_HAVE_DBHOST}"
    require_config_key "dbname" "${CFG_HAVE_DBNAME}"
    require_config_key "dbuser" "${CFG_HAVE_DBUSER}"
    require_config_key "dbpass" "${CFG_HAVE_DBPASS}"

    case "${CFG_DBTYPE}" in
        mysqli|mariadb|mysql)
            DB_BACKEND="mysql"
            ;;
        pgsql)
            DB_BACKEND="postgresql"
            ;;
        *)
            die "unsupported Moodle dbtype for this script: ${CFG_DBTYPE}"
            ;;
    esac

    if [[ -n "${CFG_DBPORT}" && ! "${CFG_DBPORT}" =~ ^[0-9]+$ ]]; then
        die "Moodle dbport must be numeric when set"
    fi

    if [[ "${RUN_DATA}" == "true" ]]; then
        require_config_key "dataroot" "${CFG_HAVE_DATAROOT}"
        dataroot="${CFG_DATAROOT}"

        if ! resolved="$(resolve_existing_dir "${dataroot}")"; then
            die "moodledata path does not exist: ${dataroot}"
        fi

        CFG_DATAROOT="${resolved}"

        if [[ ! -r "${CFG_DATAROOT}" ]]; then
            die "moodledata path is not readable: ${CFG_DATAROOT}"
        fi

        if is_path_within "${BACKUP_PATH}" "${CFG_DATAROOT}"; then
            die "refusing to write backups inside moodledata: ${BACKUP_PATH}"
        fi
    fi
}


require_command () {
    local command_name="$1"

    if ! command -v "${command_name}" >/dev/null 2>&1; then
        die "required command not found: ${command_name}"
    fi
}


preflight_tools () {
    if [[ -z "${BASH_VERSION:-}" ]]; then
        die "this script must be run with bash"
    fi

    require_command "date"
    require_command "dirname"
    require_command "basename"
    require_command "tar"
    require_command "gzip"

    if [[ "${RUN_FILES}" == "true" || "${RUN_DATA}" == "true" ]]; then
        require_command "find"
    fi

    if [[ "${RUN_DB}" == "true" ]]; then
        case "${DB_BACKEND}" in
            mysql)
                require_command "mysql"
                require_command "mysqldump"
                ;;
            postgresql)
                require_command "psql"
                require_command "pg_dump"
                ;;
        esac
    fi

    if [[ "${SINGLE_ARCHIVE}" == "true" ]]; then
        require_command "mktemp"
    fi

    if [[ -n "${EMAIL_ADDRESS}" ]]; then
        if command -v mutt >/dev/null 2>&1; then
            :
        elif command -v sendmail >/dev/null 2>&1; then
            require_command "base64"
        else
            die "email requested but neither mutt nor sendmail is available"
        fi
    fi
}


first_unreadable_tree_entry () {
    local path="$1"
    local mode="$2"

    if [[ "${mode}" == "moodledata" ]]; then
        find "${path}" \
            \( -path "${path}/cache" -o -path "${path}/temp" -o -path "${path}/trashdir" \) -prune -o \
            \( \
                \( -type d \( ! -readable -o ! -executable \) \) -o \
                \( -type f ! -readable \) \
            \) -print -quit
    else
        find "${path}" \
            \( \
                \( -type d \( ! -readable -o ! -executable \) \) -o \
                \( -type f ! -readable \) \
            \) -print -quit
    fi
}


check_tree_access () {
    local label="$1"
    local path="$2"
    local mode="$3"
    local unreadable
    local status

    unreadable="$(first_unreadable_tree_entry "${path}" "${mode}" 2>&1)"
    status="$?"

    if [[ -n "${unreadable}" ]]; then
        die "${label} contains unreadable paths; run with sufficient permissions: ${unreadable%%$'\n'*}"
    fi

    if [[ "${status}" -ne 0 ]]; then
        die "${label} could not be fully checked; run with sufficient permissions"
    fi
}


preflight_access () {
    if [[ "${RUN_FILES}" == "true" ]]; then
        check_tree_access "Moodle webroot" "${MOODLE_PATH}" "webroot"
    fi

    if [[ "${RUN_DATA}" == "true" ]]; then
        check_tree_access "moodledata" "${CFG_DATAROOT}" "moodledata"
    fi
}


validate_email () {
    if [[ -z "${EMAIL_ADDRESS}" ]]; then
        return
    fi

    if [[ ! "${EMAIL_ADDRESS}" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]]; then
        die "invalid email address: ${EMAIL_ADDRESS}"
    fi
}


mysql_command () {
    local query="$1"
    local mysql_args=(
        --host="${CFG_DBHOST}"
        --user="${CFG_DBUSER}"
        --batch
        --skip-column-names
    )

    if [[ -n "${CFG_DBPORT}" ]]; then
        mysql_args+=(--port="${CFG_DBPORT}")
    fi

    MYSQL_PWD="${CFG_DBPASS}" mysql \
        "${mysql_args[@]}" \
        "${CFG_DBNAME}" \
        --execute="${query}"
}


postgresql_command () {
    local query="$1"
    local postgresql_args=(
        --username="${CFG_DBUSER}"
        --dbname="${CFG_DBNAME}"
        --tuples-only
        --no-align
        --quiet
        --no-psqlrc
        --no-password
        --set=ON_ERROR_STOP=1
    )

    if [[ -n "${CFG_DBHOST}" ]]; then
        postgresql_args+=(--host="${CFG_DBHOST}")
    fi

    if [[ -n "${CFG_DBPORT}" ]]; then
        postgresql_args+=(--port="${CFG_DBPORT}")
    fi

    PGPASSWORD="${CFG_DBPASS}" psql "${postgresql_args[@]}" --command="${query}"
}


database_client_available () {
    case "${DB_BACKEND}" in
        mysql)
            command -v mysql >/dev/null 2>&1
            ;;
        postgresql)
            command -v psql >/dev/null 2>&1
            ;;
        *)
            return 1
            ;;
    esac
}


database_label () {
    case "${DB_BACKEND}" in
        mysql)
            printf '%s\n' "MySQL/MariaDB"
            ;;
        postgresql)
            printf '%s\n' "PostgreSQL"
            ;;
        *)
            printf '%s\n' "${CFG_DBTYPE}"
            ;;
    esac
}


database_command () {
    local query="$1"

    case "${DB_BACKEND}" in
        mysql)
            mysql_command "${query}"
            ;;
        postgresql)
            postgresql_command "${query}"
            ;;
        *)
            return 1
            ;;
    esac
}


preflight_database () {
    if [[ "${RUN_DB}" != "true" ]]; then
        return
    fi

    database_command "SELECT 1" >/dev/null
    checkerr "$(database_label) connection check" "$?"
}


sanitize_filename () {
    local value="$1"

    value="${value//[!A-Za-z0-9._-]/_}"
    value="${value##_}"
    value="${value%%_}"

    if [[ -z "${value}" ]]; then
        value="moodle"
    fi

    printf '%s\n' "${value}"
}


query_site_name () {
    local query
    local result

    SITE_NAME=""
    query="SELECT shortname FROM ${CFG_PREFIX}course WHERE sortorder = 1 LIMIT 1"

    if database_client_available; then
        if result="$(database_command "${query}" 2>/dev/null)"; then
            SITE_NAME="$(sanitize_filename "${result}")"
        fi
    fi

    if [[ -z "${SITE_NAME}" ]]; then
        if [[ -n "${CFG_DBNAME}" ]]; then
            SITE_NAME="$(sanitize_filename "${CFG_DBNAME}")"
        else
            SITE_NAME="$(sanitize_filename "$(basename "${MOODLE_PATH}")")"
        fi
    fi
}


prepare_output_paths () {
    local dbname

    TIMESTAMP="$(date +%Y-%m-%d--%H%M%S)"
    dbname="$(sanitize_filename "${CFG_DBNAME}")"

    if [[ "${SINGLE_ARCHIVE}" == "true" ]]; then
        if [[ "${DRY_RUN}" == "true" ]]; then
            OUTPUT_WORK_DIR="${BACKUP_PATH}/.moodle_autoback.${TIMESTAMP}.XXXXXX"
        else
            STAGING_DIR="$(mktemp -d "${BACKUP_PATH}/.moodle_autoback.${TIMESTAMP}.XXXXXX")"
            OUTPUT_WORK_DIR="${STAGING_DIR}"
        fi

        BUNDLE_ARCHIVE="${BACKUP_PATH}/${SITE_NAME}_full_backup_${TIMESTAMP}.tar.gz"
    else
        OUTPUT_WORK_DIR="${BACKUP_PATH}"
    fi

    DB_ARCHIVE="${OUTPUT_WORK_DIR}/${SITE_NAME}_DB_${dbname}_backup_${TIMESTAMP}.sql.gz"
    FILES_ARCHIVE="${OUTPUT_WORK_DIR}/${SITE_NAME}_files_backup_${TIMESTAMP}.tar.gz"
    DATA_ARCHIVE="${OUTPUT_WORK_DIR}/${SITE_NAME}_moodledata_backup_${TIMESTAMP}.tar.gz"
}


print_plan () {
    echo -e "${info} Moodle path: ${MOODLE_PATH}"
    echo -e "${info} Config file: ${CONFIG_FILE}"
    echo -e "${info} Backup path: ${BACKUP_PATH}"
    echo -e "${info} Site name: ${SITE_NAME}"
    echo -e "${info} Timestamp: ${TIMESTAMP}"

    if [[ "${DEBUG}" == "true" ]]; then
        echo -e "${info} Config parser: ${CONFIG_PARSER}"
        echo -e "${info} DB type: ${CFG_DBTYPE}"
        echo -e "${info} DB host: ${CFG_DBHOST}"
        if [[ -n "${CFG_DBPORT}" ]]; then
            echo -e "${info} DB port: ${CFG_DBPORT}"
        else
            echo -e "${info} DB port: [default]"
        fi
        echo -e "${info} DB name: ${CFG_DBNAME}"
        echo -e "${info} DB user: ${CFG_DBUSER}"
        if [[ "${CFG_HAVE_DBPASS}" == "true" && -n "${CFG_DBPASS}" ]]; then
            echo -e "${info} DB pass: [set]"
        else
            echo -e "${info} DB pass: [empty]"
        fi
        echo -e "${info} Table prefix: ${CFG_PREFIX}"
        if [[ "${CFG_HAVE_DATAROOT}" == "true" ]]; then
            echo -e "${info} Moodledata path: ${CFG_DATAROOT}"
        fi
        if [[ "${CFG_HAVE_WWWROOT}" == "true" ]]; then
            echo -e "${info} Moodle wwwroot: ${CFG_WWWROOT}"
        fi
    fi

    if [[ "${SINGLE_ARCHIVE}" == "true" ]]; then
        echo -e "${info} Single archive: ${BUNDLE_ARCHIVE}"
        echo -e "${info} Component staging path: ${OUTPUT_WORK_DIR}"
    fi

    if [[ "${RUN_DB}" == "true" ]]; then
        echo -e "${info} Database archive: ${DB_ARCHIVE}"
    fi

    if [[ "${RUN_FILES}" == "true" ]]; then
        echo -e "${info} Webroot archive: ${FILES_ARCHIVE}"
    fi

    if [[ "${RUN_DATA}" == "true" ]]; then
        echo -e "${info} Moodledata archive: ${DATA_ARCHIVE}"
    fi

    if [[ -n "${EMAIL_ADDRESS}" ]]; then
        echo -e "${info} Email recipient: ${EMAIL_ADDRESS}"
    fi
}


backup_mysql_database () {
    local mysqldump_args=(
        --max_allowed_packet=2G
        --skip-extended-insert
        --net_buffer_length=50000
        --host="${CFG_DBHOST}"
        --user="${CFG_DBUSER}"
    )

    if [[ -n "${CFG_DBPORT}" ]]; then
        mysqldump_args+=(--port="${CFG_DBPORT}")
    fi

    MYSQL_PWD="${CFG_DBPASS}" mysqldump "${mysqldump_args[@]}" "${CFG_DBNAME}" | gzip -c > "${DB_ARCHIVE}"
}


backup_postgresql_database () {
    local pg_dump_args=(
        --username="${CFG_DBUSER}"
        --dbname="${CFG_DBNAME}"
        --format=plain
        --no-owner
        --no-privileges
        --no-password
    )

    if [[ -n "${CFG_DBHOST}" ]]; then
        pg_dump_args+=(--host="${CFG_DBHOST}")
    fi

    if [[ -n "${CFG_DBPORT}" ]]; then
        pg_dump_args+=(--port="${CFG_DBPORT}")
    fi

    PGPASSWORD="${CFG_DBPASS}" pg_dump "${pg_dump_args[@]}" | gzip -c > "${DB_ARCHIVE}"
}


backup_database () {
    echo -e "${info} Starting database backup of ${CFG_DBNAME}"

    case "${DB_BACKEND}" in
        mysql)
            backup_mysql_database
            ;;
        postgresql)
            backup_postgresql_database
            ;;
        *)
            return 1
            ;;
    esac

    checkerr "database backup" "$?"

    EMAIL_ATTACHMENTS+=("${DB_ARCHIVE}")
}


backup_webroot () {
    local moodle_parent
    local moodle_base

    moodle_parent="$(dirname "${MOODLE_PATH}")"
    moodle_base="$(basename "${MOODLE_PATH}")"

    echo -e "${info} Starting webroot backup of ${MOODLE_PATH}"
    tar -czf "${FILES_ARCHIVE}" -C "${moodle_parent}" "${moodle_base}"
    checkerr "webroot backup" "$?"

    EMAIL_ATTACHMENTS+=("${FILES_ARCHIVE}")
}


backup_moodledata () {
    local data_parent
    local data_base

    data_parent="$(dirname "${CFG_DATAROOT}")"
    data_base="$(basename "${CFG_DATAROOT}")"

    echo -e "${info} Starting moodledata backup of ${CFG_DATAROOT}"
    echo -e "${info} Excluding ${CFG_DATAROOT}/cache, ${CFG_DATAROOT}/temp, and ${CFG_DATAROOT}/trashdir"

    tar \
        --exclude="${data_base}/cache" \
        --exclude="${data_base}/temp" \
        --exclude="${data_base}/trashdir" \
        -czf "${DATA_ARCHIVE}" \
        -C "${data_parent}" \
        "${data_base}"
    checkerr "moodledata backup" "$?"

    EMAIL_ATTACHMENTS+=("${DATA_ARCHIVE}")
}


bundle_archives () {
    local archive
    local bundle_items=()

    for archive in "${EMAIL_ATTACHMENTS[@]}"; do
        bundle_items+=("$(basename "${archive}")")
    done

    echo -e "${info} Creating single archive ${BUNDLE_ARCHIVE}"
    tar -czf "${BUNDLE_ARCHIVE}" -C "${OUTPUT_WORK_DIR}" "${bundle_items[@]}"
    checkerr "single archive bundle" "$?"

    EMAIL_ATTACHMENTS=("${BUNDLE_ARCHIVE}")
}


send_email_with_mutt () {
    local subject="$1"
    local body="$2"
    local mutt_args=()
    local attachment

    mutt_args=(-s "${subject}")

    for attachment in "${EMAIL_ATTACHMENTS[@]}"; do
        mutt_args+=(-a "${attachment}")
    done

    mutt "${mutt_args[@]}" -- "${EMAIL_ADDRESS}" <<< "${body}"
}


send_email_with_sendmail () {
    local subject="$1"
    local body="$2"
    local boundary
    local attachment
    local filename

    boundary="moodle-autoback-${TIMESTAMP}-$$"

    {
        echo "To: ${EMAIL_ADDRESS}"
        echo "Subject: ${subject}"
        echo "MIME-Version: 1.0"
        echo "Content-Type: multipart/mixed; boundary=\"${boundary}\""
        echo
        echo "--${boundary}"
        echo "Content-Type: text/plain; charset=\"utf-8\""
        echo "Content-Transfer-Encoding: 7bit"
        echo
        echo "${body}"

        for attachment in "${EMAIL_ATTACHMENTS[@]}"; do
            filename="$(basename "${attachment}")"
            echo "--${boundary}"
            echo "Content-Type: application/gzip; name=\"${filename}\""
            echo "Content-Disposition: attachment; filename=\"${filename}\""
            echo "Content-Transfer-Encoding: base64"
            echo
            base64 "${attachment}"
            echo
        done

        echo "--${boundary}--"
    } | sendmail -t
}


send_email () {
    local host_name
    local subject
    local body

    if [[ -z "${EMAIL_ADDRESS}" ]]; then
        return
    fi

    host_name="${HOSTNAME:-$(hostname 2>/dev/null || echo unknown-host)}"
    subject="${host_name} Moodle backup for ${SITE_NAME} at ${TIMESTAMP}"
    body="Moodle backup for ${SITE_NAME} completed at ${TIMESTAMP} on ${host_name}."

    echo -e "${info} Emailing backup archive(s) to ${EMAIL_ADDRESS}"

    if command -v mutt >/dev/null 2>&1; then
        send_email_with_mutt "${subject}" "${body}"
        checkerr "email backup with mutt" "$?"
    else
        send_email_with_sendmail "${subject}" "${body}"
        checkerr "email backup with sendmail" "$?"
    fi
}


cleanup () {
    if [[ -n "${STAGING_DIR}" && -d "${STAGING_DIR}" ]]; then
        rm -rf "${STAGING_DIR}"
    fi
}


main () {
    parse_args "$@"
    load_checkerr
    trap cleanup EXIT

    validate_paths
    parse_moodle_config
    validate_config
    validate_email
    preflight_tools
    preflight_database
    preflight_access
    query_site_name
    prepare_output_paths

    if [[ "${DEBUG}" == "true" || "${DRY_RUN}" == "true" ]]; then
        print_plan
    fi

    if [[ "${DRY_RUN}" == "true" ]]; then
        echo -e "${done} dry run complete; no archives written"
        exit 0
    fi

    if [[ "${RUN_DB}" == "true" ]]; then
        backup_database
    fi

    if [[ "${RUN_FILES}" == "true" ]]; then
        backup_webroot
    fi

    if [[ "${RUN_DATA}" == "true" ]]; then
        backup_moodledata
    fi

    if [[ "${SINGLE_ARCHIVE}" == "true" ]]; then
        bundle_archives
    fi

    send_email

    echo -e "${done} backup complete"
}


main "$@"
