        return 1
    fi

    while IFS=$'\t' read -r key value; do
        if [[ -z "${key}" ]]; then
            continue
        fi

        found_config="true"
        assign_config_value "${key}" "${value}"
    done <<< "${output}"

    if [[ "${found_config}" != "true" ]]; then
        return 1
    fi

