usage () {
    cat <<EOF
Usage:
  ${SCRIPT_NAME} /path/to/moodle [options]
  ${SCRIPT_NAME} --moodlepath /path/to/moodle [options]

Options:
  -m, --moodlepath PATH       Moodle webroot path.
  -b, --backup-path PATH      Backup output directory.
      --db-only               Back up the database only.
      --files-only            Back up the Moodle webroot only.
      --data-only             Back up moodledata only.
      --single-archive        Bundle selected backup archives into one tar.gz file.
      --bundle                Alias for --single-archive.
      --dry-run               Show the backup plan without writing archives.
  -d, --debug                 Show detailed configuration and backup plan.
  -e, --email ADDRESS         Email completed backup archive(s).
  -v, --version               Show version.
  -h, --help                  Show this help.

Default backup path:
  If no backup path is specified, ${SCRIPT_NAME} checks for backups/ then backup/
  beside the Moodle webroot. If neither exists, it uses the current directory.
EOF
}


die () {
    local message="$1"

    if [[ -n "${err:-}" ]]; then
        echo -e "${err}${message}" >&2
    else
        echo "ERROR: ${message}" >&2
    fi

    exit 1
}


load_checkerr () {
    if [[ ! -r "${CHECKERR_FILE}" ]]; then
        die "checkerr include not found or not readable: ${CHECKERR_FILE}"
    fi

    # shellcheck source=checkerr.inc.sh
    . "${CHECKERR_FILE}"

    if [[ "${checkerr_loaded:-false}" != "true" ]]; then
        die "checkerr include did not load correctly"
    fi
}


require_arg () {
    local option="$1"
    local value="${2:-}"

    if [[ -z "${value}" || "${value}" == --* ]]; then
        die "${option} requires a value"
    fi
}


parse_args () {
    local positional=()

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "${VERSION}"
                exit 0
                ;;
            -m|--moodlepath)
                require_arg "$1" "${2:-}"
                MOODLE_PATH="$2"
                shift 2
                ;;
            -m=*|--moodlepath=*)
                MOODLE_PATH="${1#*=}"
                shift
                ;;
            -b|--backup-path|--backuppath)
                require_arg "$1" "${2:-}"
                BACKUP_PATH="$2"
                shift 2
                ;;
            -b=*|--backup-path=*|--backuppath=*)
                BACKUP_PATH="${1#*=}"
                shift
                ;;
            -e|--email)
                require_arg "$1" "${2:-}"
                EMAIL_ADDRESS="$2"
                shift 2
                ;;
            -e=*|--email=*)
                EMAIL_ADDRESS="${1#*=}"
                shift
                ;;
            --db-only)
                ANY_ONLY_MODE="true"
                RUN_DB="true"
                shift
                ;;
            --files-only)
                ANY_ONLY_MODE="true"
                RUN_FILES="true"
                shift
                ;;
            --data-only)
                ANY_ONLY_MODE="true"
                RUN_DATA="true"
                shift
                ;;
            --single-archive|--bundle)
                SINGLE_ARCHIVE="true"
                shift
                ;;
            --dry-run)
                DRY_RUN="true"
                shift
                ;;
            -d|--debug)
                DEBUG="true"
                shift
                ;;
            --)
                shift
                while [[ "$#" -gt 0 ]]; do
                    positional+=("$1")
                    shift
                done
                ;;
            -*)
                die "unknown option: $1"
                ;;
            *)
                positional+=("$1")
                shift
                ;;
        esac
    done

    if [[ "${ANY_ONLY_MODE}" != "true" ]]; then
        RUN_DB="true"
        RUN_FILES="true"
        RUN_DATA="true"
    fi

    if [[ -z "${MOODLE_PATH}" && "${#positional[@]}" -eq 1 ]]; then
        MOODLE_PATH="${positional[0]}"
    elif [[ -n "${MOODLE_PATH}" && "${#positional[@]}" -eq 0 ]]; then
        :
    elif [[ -n "${MOODLE_PATH}" && "${#positional[@]}" -eq 1 ]]; then
        die "specify the Moodle path once, either positionally or with --moodlepath"
    else
        die "exactly one Moodle path is required"
    fi
}


trim_trailing_slashes () {
    local path="$1"

    while [[ "${path}" != "/" && "${path}" == */ ]]; do
        path="${path%/}"
    done

    printf '%s\n' "${path}"
}


resolve_existing_dir () {
    local path="$1"

    path="$(trim_trailing_slashes "${path}")"

    if [[ ! -d "${path}" ]]; then
        return 1
    fi

    (cd "${path}" && pwd -P)
}


is_path_within () {
    local child
    local parent

    child="$(trim_trailing_slashes "$1")"
    parent="$(trim_trailing_slashes "$2")"

    [[ "${child}" == "${parent}" || "${child}" == "${parent}/"* ]]
}


choose_backup_path () {
    local moodle_parent
    local candidate
    local cwd
    local resolved

    if [[ -n "${BACKUP_PATH}" ]]; then
        if ! resolved="$(resolve_existing_dir "${BACKUP_PATH}")"; then
            die "backup path does not exist: ${BACKUP_PATH}"
        fi

        BACKUP_PATH="${resolved}"
        return
    fi

    moodle_parent="$(dirname "${MOODLE_PATH}")"

    for candidate in "${moodle_parent}/backups" "${moodle_parent}/backup"; do
        if [[ -d "${candidate}" ]]; then
            if ! resolved="$(resolve_existing_dir "${candidate}")"; then
                die "backup path does not exist: ${candidate}"
            fi

            BACKUP_PATH="${resolved}"
            return
        fi
    done

    cwd="$(pwd -P)"
    BACKUP_PATH="${cwd}"
}


validate_paths () {
    local cwd
    local resolved

    if ! resolved="$(resolve_existing_dir "${MOODLE_PATH}")"; then
        die "Moodle path does not exist: ${MOODLE_PATH}"
    fi

    MOODLE_PATH="${resolved}"
    CONFIG_FILE="${MOODLE_PATH}/config.php"
    cwd="$(pwd -P)"

    if is_path_within "${cwd}" "${MOODLE_PATH}"; then
        die "refusing to run from inside the Moodle webroot: ${MOODLE_PATH}"
    fi

    if [[ ! -r "${CONFIG_FILE}" ]]; then
        die "Moodle config.php is not readable: ${CONFIG_FILE}"
    fi

    choose_backup_path

    if [[ ! -w "${BACKUP_PATH}" ]]; then
        die "backup path is not writable: ${BACKUP_PATH}"
    fi

    if is_path_within "${BACKUP_PATH}" "${MOODLE_PATH}"; then
        die "refusing to write backups inside the Moodle webroot: ${BACKUP_PATH}"
    fi
}


assign_config_value () {
    local key="$1"
    local value="$2"

    case "${key}" in
        dbtype)
            CFG_DBTYPE="${value}"
            CFG_HAVE_DBTYPE="true"
            ;;
        dbhost)
            CFG_DBHOST="${value}"
            CFG_HAVE_DBHOST="true"
            ;;
        dbname)
            CFG_DBNAME="${value}"
            CFG_HAVE_DBNAME="true"
            ;;
        dbuser)
            CFG_DBUSER="${value}"
            CFG_HAVE_DBUSER="true"
            ;;
        dbpass)
            CFG_DBPASS="${value}"
            CFG_HAVE_DBPASS="true"
            ;;
        dbport)
            CFG_DBPORT="${value}"
            ;;
        prefix)
            CFG_PREFIX="${value}"
            CFG_HAVE_PREFIX="true"
            ;;
        dataroot)
            CFG_DATAROOT="${value}"
            CFG_HAVE_DATAROOT="true"
            ;;
        wwwroot)
            CFG_WWWROOT="${value}"
            CFG_HAVE_WWWROOT="true"
            ;;
    esac
}


