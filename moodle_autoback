    local output
    local key
    local value
    local found_config="false"

    if ! command -v php >/dev/null 2>&1; then
        return 1
    fi

    if ! output="$(MOODLE_AUTOBACK_CONFIG_FILE="${CONFIG_FILE}" php -d display_errors=stderr <<'PHP' 2>/dev/null
<?php
$file = getenv('MOODLE_AUTOBACK_CONFIG_FILE');

if ($file === false || !is_readable($file)) {
    exit(1);
}

$source = file_get_contents($file);

