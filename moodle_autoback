function moodle_autoback_strip_setup_require(string $source): string {
    $tokens = token_get_all($source);
    $output = '';
    $count = count($tokens);

    for ($i = 0; $i < $count; $i++) {
        $token = $tokens[$i];

        if (is_array($token) && ($token[0] === T_OPEN_TAG || $token[0] === T_CLOSE_TAG)) {
            continue;
        }

        if (is_array($token) && in_array($token[0], [T_REQUIRE, T_REQUIRE_ONCE, T_INCLUDE, T_INCLUDE_ONCE], true)) {
            $statement = $token[1];
            $j = $i + 1;

            while ($j < $count) {
                $part = $tokens[$j];
                $text = is_array($part) ? $part[1] : $part;
                $statement .= $text;

                if ($text === ';') {
                    break;
                }

                $j++;
            }

            if (strpos($statement, 'setup.php') !== false) {
                $i = $j;
                continue;
            }

            $output .= $statement;
            $i = $j;
            continue;
        }

        $output .= is_array($token) ? $token[1] : $token;
    }

    return $output;
}

$source = moodle_autoback_strip_setup_require($source);
$bufferlevel = ob_get_level();

try {
    chdir(dirname($file));
    ob_start();
    eval($source);

