if (!isset($CFG) || !is_object($CFG)) {
    exit(1);
}

function moodle_autoback_print_config_value(string $key, $value): void {
    if (is_bool($value)) {
        $value = $value ? '1' : '0';
    } elseif ($value === null) {
        $value = '';
    } elseif (is_scalar($value)) {
        $value = (string)$value;
    } else {
        return;
    }

    $value = str_replace(["\r", "\n", "\t"], [' ', ' ', ' '], $value);
    echo $key . "\t" . $value . "\n";
}

$keys = ['dbtype', 'dbhost', 'dbname', 'dbuser', 'dbpass', 'prefix', 'dataroot', 'wwwroot'];

foreach ($keys as $key) {
    if (!property_exists($CFG, $key)) {
        continue;
    }

    moodle_autoback_print_config_value($key, $CFG->{$key});
}

